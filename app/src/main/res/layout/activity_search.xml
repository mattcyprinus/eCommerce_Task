<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#f8f8f8"
    tools:context=".Search">
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <LinearLayout
            android:id="@+id/main"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/rounded_box"
            android:padding="24dp"
            android:layout_marginTop="10dp">

            <!-- Header -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="24dp">

                <TextView
                    android:id="@+id/back_button"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="←"
                    android:textSize="32sp"
                    android:textColor="#004E64"
                    android:padding="4dp" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="Search"
                    android:textSize="32sp"
                    android:textStyle="bold"
                    android:textColor="#004E64"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="⚙"
                    android:textSize="28sp"
                    android:textColor="#004E64"/>
            </LinearLayout>

            <!-- Search Bar -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:orientation="horizontal"
                android:background="#F0F0F0"
                android:paddingHorizontal="16dp"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="⌕"
                    android:textSize="24sp"
                    android:textColor="#757575" />

                <EditText
                    android:id="@+id/search_input"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@null"
                    android:hint="Search for items..."
                    android:paddingHorizontal="12dp"
                    android:textSize="18sp"
                    android:inputType="text"
                    android:imeOptions="actionSearch"/>
            </LinearLayout>

            <!-- Search Results -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/search_results_rv"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                tools:listitem="@layout/cart_item"
                tools:itemCount="2" />

            <!-- Empty State -->
            <TextView
                android:id="@+id/empty_state_tv"
                android:layout_width="match_parent"
                android:layout_height="200dp"
                android:gravity="center"
                android:text="Start searching for products!"
                android:textSize="18sp"
                android:textColor="#757575"
                android:visibility="gone" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#D5D5D5"
                android:layout_marginTop="28dp"/>

            <!-- Bottom Nav Placeholder -->
            <include layout="@layout/activity_cart" android:layout_width="match_parent" android:layout_height="wrap_content" />
            <!-- Note: You might want to extract the Bottom Nav to a separate layout file for reuse -->

        </LinearLayout>
    </LinearLayout>
</ScrollView>